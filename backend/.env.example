# Konfigurasi Backend AURA

# Port Flask API (default 8080)
PORT=8080

# Flag Mode (Set true untuk tidak memakai Firestore - mode demo/development lokal)
MOCK_DB=true

# Google Gemini API Key
GEMINI_API_KEY="your-gemini-api-key-here"

# Path ke file serviceAccountKey.json dari Firebase Console
# Kosongkan atau abaikan jika MOCK_DB=true
GOOGLE_APPLICATION_CREDENTIALS="path/to/serviceAccountKey.json"
